{
    "name": "@pcupka/dripbird",
    "version": "0.1.0",
    "tasks": {
        "fmt": "deno fmt",
        "fmt:check": "deno fmt --check",
        "lint": "deno lint",
        "test": "deno test --allow-all",
        "test:coverage": "scripts/check_coverage.sh"
    },
    "fmt": {
        "lineWidth": 84,
        "indentWidth": 4,
        "include": ["src/", "tests/", "*.md"]
    },
    "lint": {
        "include": ["src/", "tests/"]
    },
    "compilerOptions": {
        "strict": true
    },
    "exports": "./src/main.ts",
    "imports": {
        "@std/assert": "jsr:@std/assert@^1.0.19",
        "@std/yaml": "jsr:@std/yaml@^1.0",
        "@babel/parser": "npm:@babel/parser@^7.27",
        "recast": "npm:recast@^0.23"
    }
}
